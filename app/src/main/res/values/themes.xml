<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.JenuGumpu" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/honey_gold</item>
        <item name="colorPrimaryVariant">@color/honey_amber</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/forest_green</item>
        <item name="colorSecondaryVariant">@color/forest_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/honey_cream</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/error</item>
        <item name="android:statusBarColor">@color/honey_amber</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <style name="Theme.JenuGumpu.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:statusBarColor">@color/honey_amber</item>
        <item name="android:windowBackground">@color/honey_amber</item>
        <item name="android:navigationBarColor">@color/honey_amber</item>
    </style>

    <!-- Simple button style -->
    <style name="HoneyButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/honey_gold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="OutlinedHoneyButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/honey_gold</item>
        <item name="android:textColor">@color/honey_amber</item>
    </style>

    <!-- TextInput Style -->
    <style name="HoneyTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/honey_gold</item>
        <item name="hintTextColor">@color/honey_amber</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

</resources>
