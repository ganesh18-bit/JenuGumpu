<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_header">

    <!-- Honeycomb pattern top-left -->
    <View
        android:id="@+id/honeycomb_bg"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="-40dp"
        android:layout_marginStart="-40dp" />

    <!-- App Icon -->
    <ImageView
        android:id="@+id/splash_icon"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/ic_honey_drop_large"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/splash_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"
        android:alpha="0" />

    <!-- App Name in Kannada -->
    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ಜೇನು ಗುಂಪು"
        android:textSize="40sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.02"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/splash_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ಜೇನು ಬೇಟೆಗಾರರ ಒಕ್ಕೂಟ"
        android:textSize="16sp"
        android:textColor="#FEF3C7"
        android:fontFamily="sans-serif"
        android:layout_marginTop="8dp"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@+id/splash_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bee icons row -->
    <LinearLayout
        android:id="@+id/bee_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="32dp"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@+id/splash_tagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🐝" android:textSize="24sp" android:layout_marginEnd="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🍯" android:textSize="24sp" android:layout_marginEnd="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🌿" android:textSize="24sp" android:layout_marginEnd="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🏔️" android:textSize="24sp"/>
    </LinearLayout>

    <!-- Loading bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/splash_progress"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        android:indeterminate="true"
        app:indicatorColor="#FEF3C7"
        app:trackColor="#92400E"
        app:trackCornerRadius="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:alpha="0" />

    <!-- Version -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0  •  Forest-to-Table"
        android:textSize="12sp"
        android:textColor="#FDE68A"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
