<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/honey_cream">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp" android:paddingTop="28dp"
            android:background="@drawable/gradient_header">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💰 ಲಾಭ ಲೆಕ್ಕ"
                android:textSize="22sp" android:textStyle="bold" android:textColor="@color/white"
                android:fontFamily="sans-serif"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ಮಧ್ಯವರ್ತಿ vs ನೇರ ಮಾರಾಟ ಹೋಲಿಕೆ"
                android:textSize="14sp" android:textColor="#FDE68A"
                android:fontFamily="sans-serif" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <!-- Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp" app:cardElevation="4dp" app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp"
                    android:background="@color/white">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📝 ವಿವರ ತುಂಬಿರಿ"
                        android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/honey_dark"
                        android:fontFamily="sans-serif"
                        android:layout_marginBottom="14dp"/>

                    <!-- Honey Quantity -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="ಒಟ್ಟು ಜೇನು (ಕಿ.ಗ್ರಾ)"
                        android:layout_marginBottom="10dp"
                        app:suffixText="ಕಿ.ಗ್ರಾ"
                        style="@style/HoneyTextInput">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_calc_quantity"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:fontFamily="sans-serif"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Retail Price -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="ನೇರ ಮಾರಾಟ ಬೆಲೆ (₹/ಕಿ.ಗ್ರಾ)"
                        android:layout_marginBottom="10dp"
                        app:prefixText="₹"
                        style="@style/HoneyTextInput">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_retail_price"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:hint="450"
                            android:fontFamily="sans-serif"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Middleman Price -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="ಮಧ್ಯವರ್ತಿ ಬೆಲೆ (₹/ಕಿ.ಗ್ರಾ)"
                        android:layout_marginBottom="10dp"
                        app:prefixText="₹"
                        style="@style/HoneyTextInput">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_middleman_price"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:hint="150"
                            android:fontFamily="sans-serif"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💸 ವೆಚ್ಚಗಳು"
                        android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/honey_dark"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="6dp" android:layout_marginBottom="10dp"/>

                    <!-- Filtering Cost -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="ಶೋಧನ ವೆಚ್ಚ (₹)"
                        android:layout_marginBottom="10dp"
                        app:prefixText="₹"
                        style="@style/HoneyTextInput">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_filtering_cost"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:hint="0"
                            android:fontFamily="sans-serif"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Packaging Cost -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="ಪ್ಯಾಕೇಜಿಂಗ್ ವೆಚ್ಚ (₹)"
                        android:layout_marginBottom="10dp"
                        app:prefixText="₹"
                        style="@style/HoneyTextInput">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_packaging_cost"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:hint="0"
                            android:fontFamily="sans-serif"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Transport Cost -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="ಸಾರಿಗೆ ವೆಚ್ಚ (₹)"
                        android:layout_marginBottom="16dp"
                        app:prefixText="₹"
                        style="@style/HoneyTextInput">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_transport_cost"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:hint="0"
                            android:fontFamily="sans-serif"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Calculate Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_calculate"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="🧮 ಲೆಕ್ಕ ಹಾಕಿ"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif"
                        style="@style/HoneyButton"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== RESULTS SECTION (hidden until calculate pressed) ===== -->
            <LinearLayout
                android:id="@+id/results_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Comparison Banner -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp" app:cardElevation="6dp" app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp"
                        android:background="#1F2937">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📊 ಫಲಿತಾಂಶ"
                            android:textSize="16sp" android:textStyle="bold"
                            android:textColor="@color/honey_gold"
                            android:fontFamily="sans-serif"
                            android:layout_marginBottom="14dp"/>

                        <!-- Side-by-side comparison -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Middleman column -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical"
                                android:gravity="center" android:padding="12dp"
                                android:background="#374151">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="😔 ಮಧ್ಯವರ್ತಿ"
                                    android:textSize="13sp" android:textColor="#9CA3AF"
                                    android:fontFamily="sans-serif"/>
                                <TextView android:id="@+id/tv_middleman_total"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="₹0"
                                    android:textSize="26sp" android:textStyle="bold"
                                    android:textColor="#EF4444"
                                    android:fontFamily="sans-serif"
                                    android:layout_marginTop="4dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="ಒಟ್ಟು ಆದಾಯ"
                                    android:textSize="11sp" android:textColor="#6B7280"
                                    android:fontFamily="sans-serif"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:orientation="vertical" android:gravity="center"
                                android:layout_marginStart="8dp" android:layout_marginEnd="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="VS" android:textSize="16sp" android:textStyle="bold"
                                    android:textColor="@color/honey_gold"/>
                            </LinearLayout>

                            <!-- Direct sale column -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical"
                                android:gravity="center" android:padding="12dp"
                                android:background="#1a3a2a">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="😊 ನೇರ ಮಾರಾಟ"
                                    android:textSize="13sp" android:textColor="#9CA3AF"
                                    android:fontFamily="sans-serif"/>
                                <TextView android:id="@+id/tv_direct_total"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="₹0"
                                    android:textSize="26sp" android:textStyle="bold"
                                    android:textColor="@color/leaf_green"
                                    android:fontFamily="sans-serif"
                                    android:layout_marginTop="4dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="ನಿವ್ವಳ ಲಾಭ"
                                    android:textSize="11sp" android:textColor="#6B7280"
                                    android:fontFamily="sans-serif"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Extra Profit highlight -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center"
                            android:layout_marginTop="14dp" android:padding="12dp"
                            android:background="@drawable/grade_a_background">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🎉 ಹೆಚ್ಚುವರಿ ಲಾಭ: "
                                android:textSize="15sp" android:textStyle="bold"
                                android:textColor="@color/honey_dark"
                                android:fontFamily="sans-serif"/>
                            <TextView android:id="@+id/tv_extra_profit"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/forest_green"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Breakdown Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp" app:cardElevation="4dp" app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp"
                        android:background="@color/white">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🧾 ವಿವರ ಲೆಕ್ಕ"
                            android:textSize="16sp" android:textStyle="bold"
                            android:textColor="@color/honey_dark"
                            android:fontFamily="sans-serif"
                            android:layout_marginBottom="12dp"/>

                        <!-- Revenue row -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="ಒಟ್ಟು ಆದಾಯ"
                                android:textSize="14sp" android:textColor="@color/text_secondary"
                                android:fontFamily="sans-serif"/>
                            <TextView android:id="@+id/tv_breakdown_revenue"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="14sp" android:textColor="@color/forest_green"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <!-- Filtering cost row -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="( - ) ಶೋಧನ ವೆಚ್ಚ"
                                android:textSize="14sp" android:textColor="@color/text_secondary"
                                android:fontFamily="sans-serif"/>
                            <TextView android:id="@+id/tv_breakdown_filtering"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-₹0"
                                android:textSize="14sp" android:textColor="@color/error"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <!-- Packaging cost row -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="( - ) ಪ್ಯಾಕೇಜಿಂಗ್ ವೆಚ್ಚ"
                                android:textSize="14sp" android:textColor="@color/text_secondary"
                                android:fontFamily="sans-serif"/>
                            <TextView android:id="@+id/tv_breakdown_packaging"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-₹0"
                                android:textSize="14sp" android:textColor="@color/error"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <!-- Transport cost row -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="( - ) ಸಾರಿಗೆ ವೆಚ್ಚ"
                                android:textSize="14sp" android:textColor="@color/text_secondary"
                                android:fontFamily="sans-serif"/>
                            <TextView android:id="@+id/tv_breakdown_transport"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-₹0"
                                android:textSize="14sp" android:textColor="@color/error"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/divider" android:layout_marginVertical="8dp"/>

                        <!-- Net Profit row -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="ನಿವ್ವಳ ಲಾಭ"
                                android:textSize="16sp" android:textStyle="bold"
                                android:textColor="@color/honey_dark"
                                android:fontFamily="sans-serif"/>
                            <TextView android:id="@+id/tv_net_profit"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/forest_green"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Motivation Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp" app:cardElevation="3dp" app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="16dp"
                        android:gravity="center_vertical"
                        android:background="#F0FDF4">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🌿" android:textSize="32sp" android:layout_marginEnd="12dp"/>
                        <TextView android:id="@+id/tv_motivation"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="ನೇರ ಮಾರಾಟ ಮಾಡಿ, ಹೆಚ್ಚು ಗಳಿಸಿ!"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/forest_dark"
                            android:fontFamily="sans-serif"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
